<?xml version="1.0" encoding="utf-8"?>

    <ScrollView
        xmlns:android="http://schemas.android.com/apk/res/android"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F5F5F5">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Screen title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Event Details"
                android:textSize="14sp"
                android:textColor="#888888"
                android:layout_marginBottom="4dp"/>

            <!-- Event name -->
            <TextView
                android:id="@+id/eventTitleText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Loading..."
                android:textSize="26sp"
                android:textStyle="bold"
                android:layout_marginBottom="20dp"/>

            <!-- Details card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@android:color/white"
                android:padding="20dp"
                android:elevation="2dp"
                android:layout_marginBottom="24dp">

                <TextView
                    android:id="@+id/eventLocationText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="16sp"
                    android:layout_marginBottom="10dp"
                    android:text="📍 Location"/>

                <TextView
                    android:id="@+id/eventDateText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="16sp"
                    android:layout_marginBottom="10dp"
                    android:text="🗓 Date"/>

                <TextView
                    android:id="@+id/eventPriceText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="16sp"
                    android:layout_marginBottom="10dp"
                    android:text="💳 Price"/>

                <TextView
                    android:id="@+id/seatsText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="16sp"
                    android:text="🪑 Seats remaining"/>

            </LinearLayout>

            <!-- Confirm button -->
            <Button
                android:id="@+id/confirmBookingBtn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Confirm Booking"
                android:enabled="false"/>

            <!-- Error / status message (hidden until needed) -->
            <TextView
                android:id="@+id/statusText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textColor="#D32F2F"
                android:layout_marginTop="12dp"
                android:visibility="gone"
                android:text=""/>

        </LinearLayout>
    </ScrollView>

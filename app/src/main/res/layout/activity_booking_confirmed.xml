<?xml version="1.0" encoding="utf-8"?>
<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp">

        <!-- Big checkmark emoji -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✅"
            android:textSize="72sp"
            android:layout_marginBottom="12dp"/>

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Booking Confirmed!"
            android:textSize="26sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <!-- Subtitle -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="A confirmation email has been sent to you."
            android:textSize="14sp"
            android:textColor="#666666"
            android:gravity="center"
            android:layout_marginBottom="32dp"/>

        <!-- Details card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@android:color/white"
            android:padding="20dp"
            android:elevation="4dp"
            android:layout_marginBottom="24dp">

            <!-- Event name -->
            <TextView
                android:id="@+id/confirmedEventTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginBottom="14dp"
                android:text="Event Title"/>

            <!-- Location -->
            <TextView
                android:id="@+id/confirmedLocation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:layout_marginBottom="8dp"
                android:text="📍 Location"/>

            <!-- Date -->
            <TextView
                android:id="@+id/confirmedDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:layout_marginBottom="8dp"
                android:text="🗓 Date"/>

            <!-- Price -->
            <TextView
                android:id="@+id/confirmedPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:layout_marginBottom="8dp"
                android:text="💳 Price"/>

            <!--the confirmed Ticket-->
            <TextView
                android:id="@+id/confirmedTicketId"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:layout_marginBottom="8dp"
                android:text="🎫 Ticket: " />

            <!-- Confirmed Seat Number-->
            <TextView
                android:id="@+id/confirmedSeatNumber"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:layout_marginBottom="8dp"
                android:text="Seat #: "
                />

            <!-- Divider line -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#EEEEEE"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="12dp"/>

            <!-- Reservation ID in small grey text -->
            <TextView
                android:id="@+id/confirmedReservationId"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="#999999"
                android:text="Reservation ID: ..."/>

        </LinearLayout>

        <!-- Go home button -->
        <Button
            android:id="@+id/goHomeBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Back to Home"/>

    </LinearLayout>
</ScrollView>
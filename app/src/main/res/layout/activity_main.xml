<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">
    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1A1A2E"
        android:padding="16dp"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:text="Discover Events"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"/>

            <Button
                android:id="@+id/logoutBtn"
                android:text="Logout"
                android:textSize="12sp"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:backgroundTint="#3127b3"
                android:textColor="#FFFFFF"/>
        </LinearLayout>

        <!-- Search Bar -->
        <EditText
            android:id="@+id/searchInput"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="Search events..."
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:background="@drawable/rounded_input"
            android:inputType="text"
            android:imeOptions="actionSearch"
            android:textColor="#1A1A2E"
            android:textColorHint="#888888"/>
    </LinearLayout>

    <!-- Filter Chips Row -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:background="#FFFFFF"
        android:elevation="4dp">

        <LinearLayout
            android:id="@+id/filterChipsContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="10dp"
            android:gravity="center_vertical">

            <!-- Category chips added programmatically -->
        </LinearLayout>
    </HorizontalScrollView>

    <!-- Date filter row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="10dp"
        android:background="#FAFAFA"
        android:gravity="center_vertical">

        <TextView
            android:text="Date: "
            android:textStyle="bold"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <Button
            android:id="@+id/btnDateFilter"
            android:text="Any Date"
            android:textSize="12sp"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:backgroundTint="#E8EAF6"
            android:textColor="#3949AB"/>

        <TextView
            android:text="Location: "
            android:textStyle="bold"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <Button
            android:id="@+id/btnLocationFilter"
            android:text="Any Location"
            android:textSize="12sp"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:backgroundTint="#E8EAF6"
            android:textColor="#3949AB"/>

        <Button
            android:id="@+id/btnClearFilters"
            android:text="✕ Clear"
            android:textSize="11sp"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:layout_marginStart="8dp"
            android:backgroundTint="#FFCDD2"
            android:textColor="#C62828"
            android:visibility="gone"/>
    </LinearLayout>

    <!-- Results count -->
    <TextView
        android:id="@+id/resultsCount"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="16dp"
        android:paddingTop="6dp"
        android:paddingBottom="4dp"
        android:textSize="13sp"
        android:textColor="#666666"/>

    <!-- Events List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/eventsRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp"
        android:clipToPadding="false"/>

</LinearLayout>